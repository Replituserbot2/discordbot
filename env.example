# ─── Discord ─────────────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Get this from https://discord.com/developers/applications → your app → General Information → Application ID
CLIENT_ID=your_bot_application_id_here

# ─── Groq AI (Free!) ──────────────────────────────────────────────────────────
# Get a FREE key from https://console.groq.com → API Keys (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
